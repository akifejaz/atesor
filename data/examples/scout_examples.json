{
  "version": "2.0",
  "description": "Few-shot examples for Scout Agent - Build Plan Generation",
  "general_guidelines": {
    "always_include": [
      "Use -buildvcs=false flag for all Go builds to avoid git ownership issues",
      "Check system_info for pre-installed tools to skip redundant phases",
      "Identify main package location from go_main_info, not assumptions",
      "Set appropriate timeouts based on dependency count",
      "ANALYZE architecture-specific build patterns BEFORE creating build plan"
    ],
    "never_do": [
      "Use 'go build ./...' when module has multiple packages without main",
      "Assume main is at root without checking go_main_info",
      "Create directories or files to 'fix' path issues - fix the command instead"
    ],
    "arch_specific_detection": [
      "Look for files named with arch suffixes: *_x64.mak, *_arm64.mak, *_x86.mk",
      "Check for build directories organized by architecture",
      "If arch-specific files exist but no RISC-V, plan to CREATE them"
    ]
  },
  "examples": [
    {
      "id": "scout-000",
      "name": "Complex C/C++ with Arch-Specific Makefiles",
      "tags": [
        "cpp",
        "make",
        "arch-specific",
        "complex",
        "create-files"
      ],
      "build_system": "custom_makefile",
      "source": "manual",
      "repo_name": "7zip",
      "trigger": {
        "build_system": "unknown",
        "has_main": true,
        "arch_specific_files": [
          "cmpl_gcc_x64.mak",
          "cmpl_gcc_arm64.mak"
        ],
        "riscv_support": false
      },
      "plan": {
        "build_system": "custom_makefile",
        "has_arch_specific_build": true,
        "riscv_support_exists": false,
        "phases": [
          {
            "name": "install_dependencies",
            "commands": [
              "apk update",
              "apk add build-base nasm"
            ]
          },
          {
            "name": "create_riscv_build_files",
            "commands": [
              "cat > CPP/7zip/cmpl_gcc_riscv64.mak << 'EOF'\ninclude $(CURDIR)/../../var_gcc_riscv64.mak\ninclude $(CURDIR)/../../warn_gcc.mak\ninclude $(CURDIR)/makefile.gcc\nEOF",
              "cat > CPP/7zip/var_gcc_riscv64.mak << 'EOF'\nPLATFORM = riscv64\nO = b/g_$(PLATFORM)\nUSE_ASM =\nMY_ARCH ?=\nCROSS_COMPILE ?=\nCC = $(CROSS_COMPILE)gcc\nCXX = $(CROSS_COMPILE)g++\nEOF"
            ]
          },
          {
            "name": "build",
            "commands": [
              "make -C CPP/7zip/Bundles/Alone -f ../../cmpl_gcc_riscv64.mak -j$(nproc)"
            ]
          }
        ],
        "notes": [
          "Project uses custom architecture-specific makefiles",
          "RISC-V files need to be CREATED based on x64/arm64 patterns"
        ]
      },
      "reasoning": "When a project has architecture-specific build files, detect the pattern and include file creation in the build plan. Replace arch identifiers and disable ASM."
    },
