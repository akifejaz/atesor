          {
            "name": "install_dependencies",
            "commands": [
              "apk update",
              "apk add go"
            ]
          },
          {
            "name": "build",
            "commands": [
              "go mod tidy",
              "go build -buildvcs=false -v -o shcopy ."
            ]
          }
        ],
        "notes": [
