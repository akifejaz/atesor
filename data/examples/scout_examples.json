        "native"
      ],
      "build_system": "cmake",
      "source": "manual",
      "repo_name": "native-project",
      "trigger": {
        "build_system": "cmake",
        "has_main": false
      },
      "plan": {
        "build_system": "cmake",
        "phases": [
          {
            "name": "install_dependencies",
            "commands": [
              "apk update",
              "apk add build-base cmake"
            ]
          },
          {
            "name": "configure",
            "commands": [
              "mkdir -p build",
              "cd build && cmake .. -DCMAKE_BUILD_TYPE=Release"
            ]
          },
          {
            "name": "build",
            "commands": [
              "cd build && make -j$(nproc)"
            ]
          }
        ],
        "notes": [
          "Standard CMake workflow: configure in build/, then make. Use -j$(nproc) for parallel builds."
        ]
      },
      "reasoning": "CMake projects need out-of-source builds. Create build/ directory, run cmake from there, then make."
