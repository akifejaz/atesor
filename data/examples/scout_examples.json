        "build_system": "go",
        "phases": [
          {
            "name": "install_dependencies",
            "commands": [
              "apk update",
              "apk add go"
            ]
          },
          {
            "name": "build",
            "commands": [
              "go mod tidy",
              "go build -buildvcs=false -v -o shcopy ."
            ]
          }
        ],
        "notes": [
          "Simple Go project with main at root. Use 'go build .' with -buildvcs=false."
        ]
