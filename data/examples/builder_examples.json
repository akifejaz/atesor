      "id": "builder-006",
      "name": "CMake Build - Configure and Make",
      "tags": [
        "cmake",
        "c",
        "c++",
        "configure"
      ],
      "build_system": "cmake",
      "source": "manual",
      "repo_name": "native-project",
      "phases": [
        {
          "name": "install",
          "commands": [
            "apk add cmake build-base"
          ]
        },
        {
