{
  "version": "1.0", 
  "description": "Few-shot examples for Builder Agent - Build Execution Guidelines",
  "metadata": {
    "source": "Real execution data from RISC-V builds",
    "updated": "2026-02-20"
  },
  "general_guidelines": {
    "execution_rules": [
      "Execute phases sequentially - each phase depends on previous success",
      "Monitor command output for success indicators",
      "Proactively add -buildvcs=false to Go builds",
      "Set appropriate timeouts based on dependency count"
    ],
    "success_indicators": {
      "go": "Binary created, no errors, exit code 0",
      "cmake": "'Built target X', 'Install the project...', exit code 0",
      "make": "'Build successful', no error messages, exit code 0"
    },
    "timeout_guidelines": {
      "simple_go": "60s (5 deps)",
      "moderate_go": "180s (15 deps)", 
      "complex_go": "600s (50+ deps, CGO)",
      "c_cmake": "300s",
      "dependency_install": "60s"
    },
    "proactive_optimizations": [
      "Add -buildvcs=false to go build commands",
      "Use -j$(nproc) for make parallel builds",
      "Add GOTOOLCHAIN=auto for version mismatches",
      "Set CGO_ENABLED=1 explicitly when C deps detected"
    ]
  },
  "examples": [
    {
      "id": "builder-001",
      "name": "Simple Go Build - All Phases Succeed",
      "tags": ["go", "simple", "success"],
      "context": {
        "repo_name": "shcopy",
        "build_system": "go",
        "phases": [
          {"id": 1, "name": "install", "commands": ["apk update", "apk add go"]},
          {"id": 2, "name": "build", "commands": ["go mod tidy", "go build -buildvcs=false -v -o shcopy ."]}
        ]
      },
      "execution": {
        "phase_1": {"success": true, "duration": "7s", "output": "OK: 1234 packages\n(1/1) Installing go"},
        "phase_2": {"success": true, "duration": "26s", "output": "go: downloading 5 deps\ngithub.com/aymanbagabas/shcopy"}
      },
      "success_verification": ["Binary exists: shcopy", "File is ELF RISC-V executable", "Exit code: 0"],
      "notes": "Simple project, fast build. Total time ~33 seconds."
    },
    {
      "id": "builder-002",
      "name": "Go Build with cmd/ Subdirectory",
      "tags": ["go", "cmd", "subdirectory"],
      "context": {
        "repo_name": "shuffledns",
        "build_system": "go",
        "main_path": "cmd/shuffledns",
        "phases": [
          {"id": 1, "name": "install", "commands": ["apk update", "apk add go"]},
          {"id": 2, "name": "build", "commands": ["go mod tidy", "go build -buildvcs=false -v -o shuffledns ./cmd/shuffledns"]}
        ]
      },
      "execution": {
        "phase_1": {"success": true, "duration": "10s"},
        "phase_2": {"success": true, "duration": "33s", "output": "github.com/projectdiscovery/shuffledns"}
      },
      "success_verification": ["Binary exists: shuffledns", "Size: ~15MB", "File type: ELF 64-bit RISC-V"],
      "notes": "Standard cmd/ structure. Build path is ./cmd/shuffledns not ."
    },
    {
      "id": "builder-003",
      "name": "Complex Go Build - Many Dependencies",
      "tags": ["go", "complex", "many-deps", "slow"],
      "context": {
        "repo_name": "sing-box",
        "build_system": "go",
        "main_path": "constant/goos",
        "phases": [
          {"id": 1, "name": "install", "commands": ["apk update", "apk add go"]},
          {"id": 2, "name": "build", "commands": ["go mod tidy", "go build -buildvcs=false -v -o sing-box ./constant/goos"]}
        ],
        "dependency_count": 50
      },
      "execution": {
        "phase_1": {"success": true, "duration": "10s"},
        "phase_2": {
          "success": true,
          "duration": "158s total (157s for go mod tidy, 1s for build)",
          "output": "go: downloading 50+ packages...\ngithub.com/sagernet/sing-box"
        }
      },
      "notes": "Complex projects need longer timeouts. go mod tidy alone took 157 seconds.",
      "timeout_recommendation": 600
    },
    {
      "id": "builder-004",
      "name": "Go Module in v2 Subdirectory",
      "tags": ["go", "v2", "module-subdirectory", "cd"],
      "context": {
        "repo_name": "gogo",
        "build_system": "go",
        "module_dir": "v2",
        "phases": [
          {"id": 1, "name": "install", "commands": ["apk update", "apk add go"]},
          {"id": 2, "name": "build", "commands": ["cd v2 && go mod tidy", "cd v2 && go build -buildvcs=false -v -o ../gogo ./cmd/gogo"]}
        ]
      },
      "execution": {
        "phase_1": {"success": true, "duration": "8s"},
        "phase_2": {
          "success": true,
          "duration": "15s",
          "output": "go: downloading deps from v2/go.mod\nBinary output to parent directory"
        }
      },
      "notes": "When module_dir='v2', ALL commands in phase must start with 'cd v2 &&'. Output binary to parent with '../binary'."
    },
    {
      "id": "builder-005",
      "name": "CGO Build with SQLite",
      "tags": ["go", "cgo", "sqlite", "gcc"],
      "context": {
        "repo_name": "project-with-sqlite",
        "build_system": "go",
        "has_cgo": true,
        "phases": [
          {"id": 1, "name": "install", "commands": ["apk update", "apk add go build-base sqlite-dev"]},
          {"id": 2, "name": "build", "commands": ["go mod tidy", "CGO_ENABLED=1 go build -buildvcs=false -v -o project ."]}
        ]
      },
      "execution": {
        "phase_1": {"success": true, "duration": "15s", "output": "Installing gcc, g++, sqlite headers"},
        "phase_2": {"success": true, "duration": "45s", "output": "Compiling C code for sqlite3\nLinking with CGO"}
      },
      "notes": "CGO builds need build-base (gcc/g++) and -dev packages. Set CGO_ENABLED=1 explicitly. Longer build time."
    },
    {
      "id": "builder-006",
      "name": "CMake Build - Configure and Make",
      "tags": ["cmake", "c", "c++", "configure"],
      "context": {
        "repo_name": "native-project",
        "build_system": "cmake",
        "phases": [
          {"id": 1, "name": "install", "commands": ["apk add cmake build-base"]},
          {"id": 2, "name": "configure", "commands": ["mkdir -p build", "cd build && cmake .. -DCMAKE_BUILD_TYPE=Release"]},
          {"id": 3, "name": "build", "commands": ["cd build && make -j$(nproc)"]}
        ]
      },
      "execution": {
        "phase_1": {"success": true, "duration": "15s"},
        "phase_2": {"success": true, "duration": "5s", "output": "-- Configuring done\n-- Generating done\n-- Build files written"},
        "phase_3": {"success": true, "duration": "60s", "output": "[ 25%] Building...\n[ 50%] Building...\n[100%] Built target project"}
      },
      "success_verification": ["Build files in build/", "'Built target' in output", "Binary in build/"],
      "notes": "CMake needs build/ directory for out-of-source builds. Use -j$(nproc) for parallel compilation."
    }
  ]
}
