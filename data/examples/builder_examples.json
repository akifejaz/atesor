      "id": "builder-004",
      "name": "Go Module in v2 Subdirectory",
      "tags": [
        "go",
        "v2",
        "module-subdirectory",
        "cd"
      ],
      "build_system": "go",
      "source": "manual",
      "repo_name": "gogo",
