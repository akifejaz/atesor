      "id": "builder-005",
      "name": "CGO Build with SQLite",
      "tags": [
        "go",
        "cgo",
        "sqlite",
        "gcc"
      ],
      "build_system": "go",
      "source": "manual",
      "repo_name": "project-with-sqlite",
