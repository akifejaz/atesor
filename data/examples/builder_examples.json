      "id": "builder-004",
      "name": "Go Module in v2 Subdirectory",
      "tags": [
        "go",
        "v2",
        "module-subdirectory",
        "cd"
      ],
      "build_system": "go",
      "source": "manual",
      "repo_name": "gogo",
      "phases": [
        {
          "name": "install",
          "commands": [
            "apk update",
            "apk add go"
          ]
        },
        {
          "name": "build",
          "commands": [
            "cd v2 && go mod tidy",
            "cd v2 && go build -buildvcs=false -v -o ../gogo ./cmd/gogo"
          ]
        }
      ],
      "timeout_recommendation": "120s",
      "reasoning": "When module_dir='v2', ALL commands must start with 'cd v2 &&'. Output binary to parent."
