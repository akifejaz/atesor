        {
          "name": "install",
          "commands": [
            "apk update",
            "apk add go"
          ]
        },
        {
          "name": "build",
          "commands": [
            "cd v2 && go mod tidy",
            "cd v2 && go build -buildvcs=false -v -o ../gogo ./cmd/gogo"
          ]
        }
      ],
      "timeout_recommendation": "120s",
      "reasoning": "When module_dir='v2', ALL commands must start with 'cd v2 &&'. Output binary to parent."
    },
    {
      "id": "builder-005",
      "name": "CGO Build with SQLite",
      "tags": [
        "go",
        "cgo",
        "sqlite",
        "gcc"
      ],
      "build_system": "go",
      "source": "manual",
      "repo_name": "project-with-sqlite",
      "phases": [
        {
          "name": "install",
          "commands": [
            "apk update",
            "apk add go build-base sqlite-dev"
          ]
        },
        {
          "name": "build",
          "commands": [
            "go mod tidy",
            "CGO_ENABLED=1 go build -buildvcs=false -v -o project ."
          ]
        }
      ],
      "timeout_recommendation": "300s",
      "reasoning": "CGO builds need build-base and -dev packages. Set CGO_ENABLED=1 explicitly. Longer build time."
    },
    {
      "id": "builder-006",
      "name": "CMake Build - Configure and Make",
      "tags": [
        "cmake",
        "c",
        "c++",
        "configure"
      ],
      "build_system": "cmake",
      "source": "manual",
      "repo_name": "native-project",
      "phases": [
        {
          "name": "install",
          "commands": [
            "apk add cmake build-base"
          ]
        },
        {
          "name": "configure",
          "commands": [
            "mkdir -p build",
            "cd build && cmake .. -DCMAKE_BUILD_TYPE=Release"
          ]
        },
        {
          "name": "build",
          "commands": [
            "cd build && make -j$(nproc)"
          ]
        }
      ],
      "timeout_recommendation": "300s",
      "reasoning": "CMake needs build/ directory for out-of-source builds. Use -j$(nproc) for parallel compilation."
    },
